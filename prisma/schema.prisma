generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   @map("password_hash")
  role      Role     @default(STAFF)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("categories")
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  description String?
  price       Int
  imageUrl    String?       @map("image_url")
  status      ProductStatus @default(AVAILABLE)
  categoryId  Int           @map("category_id")
  category    Category      @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([categoryId, status, name])
  @@map("products")
}

model CafeTable {
  id        Int             @id @default(autoincrement())
  name      String          @unique
  status    TableStatus     @default(AVAILABLE)
  qrCodeUrl String?         @map("qr_code_url")
  orders    Order[]
  sessions  DiningSession[]
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@map("cafe_tables")
}

model DiningSession {
  id        Int                 @id @default(autoincrement())
  tableId   Int                 @map("table_id")
  table     CafeTable           @relation(fields: [tableId], references: [id])
  status    DiningSessionStatus @default(OPEN)
  orders    Order[]
  invoice   Invoice?
  startedAt DateTime            @default(now()) @map("started_at")
  closedAt  DateTime?           @map("closed_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  @@index([tableId, status])
  @@index([tableId, status, startedAt])
  @@map("dining_sessions")
}

model Order {
  id          Int            @id @default(autoincrement())
  tableId     Int            @map("table_id")
  table       CafeTable      @relation(fields: [tableId], references: [id])
  sessionId   Int?           @map("session_id")
  session     DiningSession? @relation(fields: [sessionId], references: [id])
  status      OrderStatus    @default(PENDING)
  totalAmount Int            @default(0) @map("total_amount")
  note        String?
  items       OrderItem[]
  invoice     Invoice?
  payment     Payment?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([tableId, status])
  @@index([sessionId, status])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int     @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
  note      String?

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Invoice {
  id            Int            @id @default(autoincrement())
  orderId       Int            @unique @map("order_id")
  order         Order          @relation(fields: [orderId], references: [id])
  sessionId     Int?           @unique @map("session_id")
  session       DiningSession? @relation(fields: [sessionId], references: [id])
  totalAmount   Int            @map("total_amount")
  paymentMethod PaymentMethod  @map("payment_method")
  paidAt        DateTime       @default(now()) @map("paid_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([paidAt])
  @@map("invoices")
}

model Payment {
  id                 Int             @id @default(autoincrement())
  orderId            Int             @unique @map("order_id")
  order              Order           @relation(fields: [orderId], references: [id])
  provider           PaymentProvider @default(SEPAY)
  status             PaymentStatus   @default(PENDING)
  amount             Int
  transferCode       String          @unique @map("transfer_code")
  qrUrl              String?         @map("qr_url")
  bankCode           String          @map("bank_code")
  accountNumber      String          @map("account_number")
  accountName        String?         @map("account_name")
  sepayTransactionId String?         @unique @map("sepay_transaction_id")
  referenceCode      String?         @map("reference_code")
  rawData            Json?           @map("raw_data")
  paidAt             DateTime?       @map("paid_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("payments")
}

enum Role {
  ADMIN
  STAFF
  CASHIER

  @@map("user_role")
}

enum ProductStatus {
  AVAILABLE
  UNAVAILABLE

  @@map("product_status")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED

  @@map("table_status")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SERVED
  PAID
  CANCELLED

  @@map("order_status")
}

enum DiningSessionStatus {
  OPEN
  CLOSED
  CANCELLED

  @@map("dining_session_status")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR_PAYMENT

  @@map("payment_method")
}

enum PaymentProvider {
  SEPAY

  @@map("payment_provider")
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED

  @@map("payment_status")
}
